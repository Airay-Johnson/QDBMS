# ============================================
# QDBMS Docker 环境变量
# 复制此文件为 .env 并修改配置
# ============================================

# MySQL 数据库 root 密码（生产环境请务必修改）
MYSQL_ROOT_PASSWORD=123456

# JWT 签名密钥（生产环境请使用随机字符串，至少 256 位）
JWT_SECRET=qdbms-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
