<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="SurveySystem.controller.QuestionnaireManageController"
      spacing="10" style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label text="问卷管理" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索问卷..." prefWidth="200"/>
        <Button text="搜索" onAction="#handleSearch"/>
        <Button text="新建问卷" onAction="#handleCreateQuestionnaire" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="questionnaireTable" prefHeight="400">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50">
                <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="titleColumn" text="标题" prefWidth="200">
                <cellValueFactory><PropertyValueFactory property="title"/></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="descriptionColumn" text="描述" prefWidth="250">
                <cellValueFactory><PropertyValueFactory property="description"/></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100">
                <cellValueFactory><PropertyValueFactory property="statusDisplay"/></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="编辑" onAction="#handleEditQuestionnaire" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="添加问题" onAction="#handleAddQuestions" style="-fx-background-color: #9C27B0; -fx-text-fill: white;"/>
        <Button text="删除" onAction="#handleDeleteQuestionnaire" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="发布" onAction="#handlePublishQuestionnaire" style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
        <Button text="取消发布" onAction="#handleUnpublishQuestionnaire" style="-fx-background-color: #795548; -fx-text-fill: white;"/>
        <Button text="查看结果" onAction="#handleViewResults" style="-fx-background-color: #607D8B; -fx-text-fill: white;"/>
        <Button text="返回" onAction="#handleBack"/>
    </HBox>
</VBox>