<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SurveySystem.controller.ViewLogsController">
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="系统日志" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <HBox spacing="10">
                <ComboBox fx:id="operationFilter" promptText="操作类型" prefWidth="150"/>
                <DatePicker fx:id="startDate" promptText="开始日期"/>
                <DatePicker fx:id="endDate" promptText="结束日期"/>
                <Button text="查询" onAction="#handleSearch" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                <Button text="刷新" onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            </HBox>
            <TableView fx:id="logTable" prefHeight="400">
                <columns>
                    <TableColumn text="时间" prefWidth="160"><cellValueFactory><PropertyValueFactory property="operationTime"/></cellValueFactory></TableColumn>
                    <TableColumn text="用户" prefWidth="100"><cellValueFactory><PropertyValueFactory property="userName"/></cellValueFactory></TableColumn>
                    <TableColumn text="操作" prefWidth="120"><cellValueFactory><PropertyValueFactory property="operation"/></cellValueFactory></TableColumn>
                    <TableColumn text="目标" prefWidth="200"><cellValueFactory><PropertyValueFactory property="target"/></cellValueFactory></TableColumn>
                    <TableColumn text="详情" prefWidth="300"><cellValueFactory><PropertyValueFactory property="details"/></cellValueFactory></TableColumn>
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
            <Button text="关闭" onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
