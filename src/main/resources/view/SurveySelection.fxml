<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="SurveySystem.controller.SurveySelectionController"
      style="-fx-background-color: #f0f2f5; -fx-padding: 20;">

    <Label text="请选择要填写的问卷" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <TableView fx:id="questionnaireTable" prefHeight="400"
               style="-fx-background-color: white; -fx-control-inner-background: white;">
        <columns>
            <TableColumn fx:id="titleColumn" text="问卷标题" prefWidth="280"/>
            <TableColumn fx:id="descColumn" text="描述" prefWidth="250"/>
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="填写选中的问卷" onAction="#handleStartSurvey"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-padding: 8 20; -fx-background-radius: 4;"/>
        <Button text="返回" onAction="#handleBack"
                style="-fx-background-color: #ecf0f1; -fx-text-fill: #555;
                       -fx-font-size: 13px; -fx-padding: 8 20; -fx-background-radius: 4;"/>
    </HBox>

</VBox>
