<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="SurveySystem.controller.DashboardController">

    <MenuBar>
        <Menu text="文件">
            <MenuItem text="退出" onAction="#handleExit"/>
        </Menu>
        <Menu text="问卷管理">
            <MenuItem fx:id="createSurveyMenuItem" text="创建问卷" onAction="#handleCreateSurvey"/>
            <MenuItem text="查看问卷" onAction="#handleViewSurveys"/>
            <MenuItem fx:id="editSurveyMenuItem" text="编辑问卷" onAction="#handleEditSurvey"/>
            <MenuItem fx:id="deleteSurveyMenuItem" text="删除问卷" onAction="#handleDeleteSurvey"/>
        </Menu>
        <Menu text="问题管理">
            <MenuItem text="添加问题" onAction="#handleAddQuestion"/>
            <MenuItem text="管理问题库" onAction="#handleManageQuestions"/>
        </Menu>
        <Menu text="数据收集">
            <MenuItem text="填写问卷" onAction="#handleSurveyResponse"/>
            <MenuItem fx:id="viewResponsesMenuItem" text="查看回答" onAction="#handleViewResponses"/>
        </Menu>
        <Menu text="数据分析">
            <MenuItem fx:id="dataAnalysisMenuItem" text="数据分析" onAction="#handleDataAnalysis"/>
            <MenuItem fx:id="exportReportsMenuItem" text="报告导出" onAction="#handleReportExport"/>
        </Menu>
        <Menu text="系统管理">
            <MenuItem fx:id="userManagementMenuItem" text="用户管理" onAction="#handleUserManagement"/>
            <MenuItem fx:id="permissionManagementMenuItem" text="权限管理" onAction="#handlePermissionManagement"/>
            <MenuItem text="查看日志" onAction="#handleViewLogs"/>
        </Menu>
        <Menu text="帮助">
            <MenuItem text="关于" onAction="#handleAbout"/>
        </Menu>
    </MenuBar>

    <HBox style="-fx-padding: 10;" spacing="10">
        <VBox spacing="10" prefWidth="300">
            <Label text="欢迎使用社会调查数据分析系统" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator/>

            <Label text="快捷操作" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Button fx:id="createSurveyButton" text="创建新问卷" onAction="#handleCreateSurvey" maxWidth="Infinity"/>
            <Button fx:id="editSurveyButton" text="编辑问卷" onAction="#handleEditSurvey" maxWidth="Infinity"/>
            <Button fx:id="deleteSurveyButton" text="删除问卷" onAction="#handleDeleteSurvey" maxWidth="Infinity"/>
            <Button fx:id="dataAnalysisButton" text="查看数据分析" onAction="#handleDataAnalysis" maxWidth="Infinity"/>
            <Button text="填写问卷" onAction="#handleSurveyResponse" maxWidth="Infinity"/>
            <Button fx:id="viewResponsesButton" text="查看回答" onAction="#handleViewResponses" maxWidth="Infinity"/>
            <Button fx:id="exportReportsButton" text="导出报告" onAction="#handleReportExport" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="10" prefWidth="600">
            <Label text="系统概览" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints prefWidth="150"/>
                </columnConstraints>

                <Label text="问卷总数:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label text="0" fx:id="surveyCountLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="问题总数:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label text="0" fx:id="questionCountLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="回答总数:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label text="0" fx:id="responseCountLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="用户总数:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label text="0" fx:id="userCountLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>

            <Separator/>

            <Label text="最近活动" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TableView fx:id="recentActivityTable" prefHeight="200">
                <columns>
                    <TableColumn text="时间" prefWidth="120"/>
                    <TableColumn text="操作" prefWidth="200"/>
                    <TableColumn text="详情" prefWidth="280"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
        <Label fx:id="welcomeLabel" text="未登录"/>
        <Button text="退出登录" onAction="#handleLogout" style="-fx-margin-left: 10;"/>
    </HBox>
</VBox>